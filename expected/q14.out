SET client_min_messages = warning;
CREATE EXTENSION pg_vec;
SET pg_vec.enabled = on;
CREATE TABLE part (
	p_partkey integer NOT NULL,
	p_type varchar(25) NOT NULL
);
CREATE TABLE lineitem (
	l_partkey integer NOT NULL,
	l_extendedprice numeric(15,2) NOT NULL,
	l_discount numeric(15,2) NOT NULL,
	l_shipdate date NOT NULL
);
INSERT INTO part (p_partkey, p_type)
VALUES
	(1, 'PROMO BURNISHED COPPER'),
	(2, 'LARGE BRUSHED TIN'),
	(3, 'PROMO ANODIZED STEEL');
INSERT INTO lineitem (l_partkey, l_extendedprice, l_discount, l_shipdate)
VALUES
	(1, 100.00, 0.00, date '1995-09-05'),
	(2, 100.00, 0.00, date '1995-09-10'),
	(3, 50.00, 0.00, date '1995-09-20'),
	(1, 80.00, 0.00, date '1995-08-31'),
	(3, 75.00, 0.00, date '1995-10-01');
SELECT
	100.00 * sum(CASE
		WHEN p_type LIKE 'PROMO%' THEN l_extendedprice * (1 - l_discount)
		ELSE 0
	END) / sum(l_extendedprice * (1 - l_discount)) AS promo_revenue
FROM lineitem, part
WHERE l_partkey = p_partkey
  AND l_shipdate >= date '1995-09-01'
  AND l_shipdate < date '1995-09-01' + interval '1 month';
    promo_revenue    
---------------------
 60.0000000000000000
(1 row)

DROP TABLE lineitem;
DROP TABLE part;
DROP EXTENSION pg_vec;
